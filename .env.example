# ============================================================
# 股票投资管理系统 — 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并根据实际情况修改
# cp .env.example .env
# ============================================================

# --- Node.js 路径（可选，默认从系统 PATH 查找）---
# NODE_PATH=/usr/local/bin/node

# --- westock-data 插件目录（必需）---
# WESTOCK_PATH=/path/to/westock-data

# --- neodata-financial-search 插件目录（可选）---
# NEODATA_PATH=/path/to/neodata-financial-search

# --- API 服务端口（默认 8766）---
# API_PORT=8766

# --- Vite 开发服务器端口（默认 5173）---
# VITE_PORT=5173

# --- Vite 代理目标地址（默认 http://127.0.0.1:8766）---
# VITE_API_TARGET=http://127.0.0.1:8766

# --- 券商账号（用于对账单解析）---
# BROKER_ACCOUNT=51312640
# BROKER_NAME=广发证券
